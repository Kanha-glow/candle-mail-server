# Google OAuth for backend admin panel
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret_here

# AES encryption key (32 bytes hex) - server-side only
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_AES_KEY_HEX=your_32_byte_hex_key_here

# Backend identifier for API authentication
# Generate with a secure random string generator
BACKEND_IDENTIFIER=your_backend_identifier_here

# Your Gmail for admin access (must match Google OAuth email)
ADMIN_EMAIL=your_admin_email@gmail.com

# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Encrypted developer email (AES-256-GCM encrypted target email)
# Generate using: node scripts/encrypt-email.js your-email@gmail.com
DEV_EMAIL_ENCRYPTED=your_encrypted_email_here
